# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# PostgreSQL (Docker / Render production)
DATABASE_URL=postgresql://authuser:CHANGE_ME_DB_PASSWORD@db:5432/authdb
POSTGRES_USER=authuser
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=authdb

# SQLite fallback for local dev (comment out DATABASE_URL above and use this)
# DATABASE_URL=sqlite:///./auth.db

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── WebAuthn Relying Party ────────────────────────────────────
# Production: RP_ID = your domain (no port, no https://)
#   e.g. RP_ID=your-app.vercel.app
# Local dev:  RP_ID=localhost
RP_ID=localhost
RP_NAME=Adaptive Auth Platform

# Production: must be full https:// origin of your frontend
#   e.g. RP_ORIGIN=https://your-app.vercel.app
# Local dev:
RP_ORIGIN=http://localhost:5173

# ── CORS ─────────────────────────────────────────────────────
# Production: set to your Vercel frontend URL only
#   e.g. CORS_ORIGINS=["https://your-app.vercel.app"]
# Local dev (default in config.py covers this):
# CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]

# ── Trust Score Thresholds (0-100) ───────────────────────────
TRUST_THRESHOLD_OK=70
TRUST_THRESHOLD_MONITOR=40
TRUST_THRESHOLD_STEPUP=20

# ── Behavioral Monitoring ────────────────────────────────────
BATCH_INTERVAL_SECONDS=5
FEATURE_WINDOW_SECONDS=10
STEPUP_TIMEOUT_SECONDS=30

# ── Demo Mode ─────────────────────────────────────────────────
# WARNING: Set to false in production!
# Demo mode exposes /demo/* routes that bypass WebAuthn entirely.
DEMO_MODE=false

# Only relevant when DEMO_MODE=true:
# DEMO_MIN_SESSIONS=1
# DEMO_MIN_VECTORS=5
