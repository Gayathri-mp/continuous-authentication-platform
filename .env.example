# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Database (PostgreSQL for Docker / SQLite fallback for local dev)
DATABASE_URL=postgresql://authuser:CHANGE_ME_DB_PASSWORD@db:5432/authdb
POSTGRES_USER=authuser
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=authdb

# JWT — generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# WebAuthn Relying Party
# RP_ID must match the domain you serve the app on (no port, no scheme)
RP_ID=localhost
RP_NAME=Adaptive Auth Platform
RP_ORIGIN=http://localhost:5173

# Trust Score Thresholds (0-100)
TRUST_THRESHOLD_OK=70
TRUST_THRESHOLD_MONITOR=40
TRUST_THRESHOLD_STEPUP=20

# Behavioral Monitoring
BATCH_INTERVAL_SECONDS=5
FEATURE_WINDOW_SECONDS=10
