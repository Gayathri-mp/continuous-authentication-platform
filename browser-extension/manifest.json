{
  "manifest_version": 3,
  "name": "YourCredence Auth Monitor",
  "short_name": "YourCredence",
  "description": "Continuous behavioral authentication monitor — watches for anomalies across all your browser tabs and shows a real-time trust score border.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YourCredence Auth Monitor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/overlay.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
